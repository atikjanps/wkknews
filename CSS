body {
  font-family: Arial;
  background: #f4f4f4;
}

.box {
  background: white;
  padding: 10px;
  margin: 10px;
  border-radius: 10px;
}

input, textarea {
  width: 100%;
  margin: 5px 0;
  padding: 8px;
}

button {
  padding: 10px;
  background: green;
  color: white;
  border: none;
}

.card {
  background: white;
  margin: 10px;
  padding: 10px;
  border-radius: 10px;
}

.card img {
  width: 100%;
}
